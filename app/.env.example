# Neon Postgres connection string
# Vercel統合の場合は自動設定される
# ローカル開発時はNeonダッシュボードからコピーして .env.local に設定する
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudflare Access チーム名（本番環境のみ必須）
# CF Access の JWT 検証に使用する。チーム名は Cloudflare Zero Trust ダッシュボードで確認できる。
# 例: team-name（https://team-name.cloudflareaccess.com に対応）
# ローカル開発時は不要（NODE_ENV=development の場合はダミー userId を使用）
CF_ACCESS_TEAM_NAME=your-team-name
